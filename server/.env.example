# Server
PORT=3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://<user>@localhost:5432/ai_talent_eval_dev"

# Authentication — Bearer token keys, comma-separated
AUTH_KEYS=sk-test-key-001,sk-test-key-002

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Mock mode — skip Gemini API, return mock result
MOCK_MODE=true

# File upload directory
UPLOAD_DIR=./uploads
